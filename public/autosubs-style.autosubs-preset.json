    "HighlightRound": 0.2,
    "HighlightColorRed": 0,
    "HighlightColorGreen": 0.208,
    "HighlightColorBlue": 1,
    "FillEnabled": 1,
    "FillColorRed": 1,
    "FillColorGreen": 1,
    "FillColorBlue": 1,
    "OutlineEnabled": 1,
    "OutlineThickness": 0.2,
    "OutlineColorRed": 0,
    "OutlineColorGreen": 0,
    "OutlineColorBlue": 0,
    "ShadowEnabled": 0,
    "ShadowColorRed": 0,
    "ShadowColorGreen": 0,
    "ShadowColorBlue": 0,
    "HighlightStyle": 3,
    "HighlightEnabled": 0
  }
